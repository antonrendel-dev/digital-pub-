# Database
DATABASE_URL=postgresql://user:password@localhost:5432/digital_pub

# Payload CMS
PAYLOAD_SECRET=           # min 32 chars, generate: openssl rand -hex 32
                          # WARNING: rotating this value invalidates all sessions and API Keys
PAYLOAD_ADMIN_EMAIL=
PAYLOAD_ADMIN_PASSWORD=
PAYLOAD_API_KEY=          # filled after first onInit run (check server logs)
DB_CONNECTION_STRING=     # postgresql://user:password@host:5432/dbname
NEXT_PUBLIC_SERVER_URL=   # https://d-pub.ru (prod) or https://staging.d-pub.ru (staging)

# NextAuth
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=https://d-pub.ru

# Admin credentials
ADMIN_EMAIL=admin@d-pub.ru
ADMIN_PASSWORD_HASH=bcrypt-hash-of-your-password

# Telegram sync
# Comma-separated channel usernames (without @)
TELEGRAM_CHANNELS=web_vacancy,digital_pub
SYNC_INTERVAL_MINUTES=10
