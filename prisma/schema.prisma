generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum PostType {
  vacancy
  resume
}

enum PostStatus {
  pending
  published
  rejected
}

enum PostSource {
  telegram
  user
}

enum TagType {
  format
  level
  specialization
}

model Post {
  id                  Int        @id @default(autoincrement())
  type                PostType
  title               String
  slug                String?   @unique
  description         String?
  company             String?
  salary              String?
  status              PostStatus @default(pending)
  source              PostSource @default(telegram)
  imageUrl            String?
  telegramMessageId   String?
  channelUsername     String?
  categoryId          Int?
  category            Category?  @relation(fields: [categoryId], references: [id])
  tags                PostTag[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([telegramMessageId, channelUsername])
}

model Tag {
  id      Int       @id @default(autoincrement())
  name    String    @unique
  tagType TagType
  posts   PostTag[]
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
